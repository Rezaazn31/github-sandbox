          var timer = setTimeout(function() {
            $('.user_sub_common_warp.follow_email').hide();
            clearTimeout(timer);
            requestPermissionAndSendThanks();
          }, 3000);
        } 
      });
    }

    
    function unsubscribeFollowApp() {
